MONGO_URL=mongodb://127.0.0.1:27017/streampure
JWT_SECRET=change-me-to-a-long-random-string
PORT=5005
ALLOWED_ORIGINS=

# Cloudflare R2 (admin-uploaded track catalog) — see DEPLOYMENT.md.
# Leave blank locally if you're not testing uploads; everything else still works.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_BASE_URL=

# Resend (transactional email for "forgot password") — see DEPLOYMENT.md.
# Leave blank locally to skip sending; forgot-password still responds
# successfully (so the frontend flow doesn't break in dev), it just logs a
# warning instead of emailing anyone.
RESEND_API_KEY=
RESEND_FROM_EMAIL=
# Used to build the link inside the reset email, e.g.
# https://streampureapp.vercel.app — no trailing slash. Defaults to the
# local Vite dev server if unset.
FRONTEND_URL=http://localhost:5173
