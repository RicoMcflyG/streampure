# Base URL the frontend uses to reach the backend API.
# Local dev: leave as-is (matches `npm start` in backend/).
# Production (Vercel): set this in the Vercel project's Environment
# Variables settings to your deployed Render backend URL, e.g.
# https://streampure-backend.onrender.com — do NOT rely on this file for
# that, Vercel ignores committed .env files at build time.
VITE_API_URL=http://localhost:5005
